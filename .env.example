# ===== EcoRoute Logistic AI — variables de entorno =====
# Copia este archivo como .env.local y completa con tus valores reales.

# URL pública de tu instancia Supabase (self-hosted)
NEXT_PUBLIC_SUPABASE_URL=https://supabase.tu-dominio.com
# Clave anónima / publishable (segura para el navegador)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Clave service_role (SOLO servidor — nunca exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Conexión Postgres directa (solo para correr migraciones con Supabase CLI)
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@HOST:5432/postgres
